#include <iostream>
#include <vector>
#include <omp.h>
using namespace std;

const int MAXN = 100;
vector<int> adj[MAXN];
bool visited[MAXN];

// Parallel DFS using tasks
void dfs(int node) {

    bool alreadyVisited;

    // Protect shared data
    #pragma omp critical
    {
        alreadyVisited = visited[node];
        if (!visited[node]) {
            visited[node] = true;
            cout << node << " ";
        }
    }

    if (alreadyVisited) return;

    // Create tasks for neighbors
    for (int next_node : adj[node]) {
        #pragma omp task
        dfs(next_node);
    }

    // Wait for all tasks to finish
    #pragma omp taskwait
}

int main() {

    cout << "Enter number of nodes and edges:\n";
    int n, m;
    cin >> n >> m;

    cout << "Enter edges (u v):\n";
    for (int i = 1; i <= m; i++) {
        int u, v;
        cin >> u >> v;
        adj[u].push_back(v);
        adj[v].push_back(u);
    }

    cout << "Enter starting node:\n";
    int start_node;
    cin >> start_node;

    cout << "Parallel DFS Traversal:\n";

    // Start OpenMP parallel region
    #pragma omp parallel
    {
        #pragma omp single
        dfs(start_node);
    }

    cout << endl;
    return 0;
}
