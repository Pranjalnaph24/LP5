#include <iostream>
#include <vector>
#include <omp.h>
using namespace std;

const int MAXN = 1e5;
vector<int> adj[MAXN+5];
bool visited[MAXN+5];

void dfs(int node) {

    bool alreadyVisited;

    #pragma omp critical
    {
        alreadyVisited = visited[node];
        if (!visited[node]) {
            visited[node] = true;
            cout << node << " ";
        }
    }

    if (alreadyVisited) return;

    for (int next_node : adj[node]) {

        #pragma omp task
        dfs(next_node);
    }
}

int main() {
    int n, m;
    cin >> n >> m;

    for (int i = 1; i <= m; i++) {
        int u, v;
        cin >> u >> v;
        adj[u].push_back(v);
        adj[v].push_back(u);
    }

    int start_node;
    cin >> start_node;

    #pragma omp parallel
    {
        #pragma omp single
        dfs(start_node);
    }

    return 0;
}
